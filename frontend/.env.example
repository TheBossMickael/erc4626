# Sepolia RPC endpoint used by the read-only client and MetaMask fallbacks.
# A free Alchemy key is recommended: the NAV timeline replays contract events
# since deployment, which public rate-limited RPCs may reject.
# The key ships in the client bundle — testnet only, restrict it by domain
# in the Alchemy dashboard.
VITE_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
