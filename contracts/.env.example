# Copy to .env and fill in. `.env` is gitignored — NEVER commit it.
# Load into the shell (Git Bash):  set -a; source .env; set +a

# Sepolia RPC endpoint (Alchemy / Infura / public node)
SEPOLIA_RPC_URL=

# Deployer EOA private key, 0x-prefixed.
# Use a throwaway demo key holding Sepolia ETH only — never a funded key.
PRIVATE_KEY=

# Etherscan API key (a v2 key covers Sepolia)
ETHERSCAN_API_KEY=
